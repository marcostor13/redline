---
interface Props {
  headline: string;
  subheadline: string;
  primaryCTA?: { href: string; label: string };
  secondaryCTA?: { href: string; label: string };
  backgroundImage?: string;
  compact?: boolean;
}

const {
  headline,
  subheadline,
  primaryCTA = { href: '/quote/', label: 'Request a Free Quote' },
  secondaryCTA = { href: 'tel:+16303637251', label: 'Call 630-363-7251' },
  backgroundImage,
  compact = false,
} = Astro.props;

const stats = [
  { value: '34+', label: 'Years in Business' },
  { value: '500+', label: 'Projects Completed' },
  { value: '50', label: 'States Served' },
  { value: '0', label: 'Subcontractors' },
];
---

<section
  class={`hero ${compact ? 'hero-compact' : 'hero-full'}`}
  aria-label="Hero"
>
  {/* Background */}
  <div
    class="hero-bg"
    style={backgroundImage ? `background-image: url('${backgroundImage}')` : ''}
    aria-hidden="true"
  />
  <div class="hero-overlay" aria-hidden="true" />
  <div class="hero-grid-pattern" aria-hidden="true" />
  <div class="hero-red-stripe" aria-hidden="true" />

  {/* Content */}
  <div class="hero-body">
    <div class="container hero-container">
      <div class="hero-content">

        <div class="hero-eyebrow hero-anim hero-anim-1">
          <span class="hero-badge">Est. 1990</span>
          <span class="hero-location">Chicago, Illinois</span>
        </div>

        <h1 class={`text-display text-white hero-headline hero-anim hero-anim-2 ${compact ? 'hero-headline-compact' : ''}`}>
          {headline}
        </h1>

        <p class="hero-sub hero-anim hero-anim-3">
          {subheadline}
        </p>

        <div class="hero-ctas hero-anim hero-anim-4">
          <a href={primaryCTA.href} class="hero-btn-primary">
            {primaryCTA.label}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href={secondaryCTA.href} class="hero-btn-secondary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {secondaryCTA.label}
          </a>
        </div>

      </div>
    </div>
  </div>

  {/* Stats bar */}
  {!compact && (
    <div class="hero-stats-bar hero-anim hero-anim-5">
      <div class="container">
        <div class="hero-stats">
          {stats.map((s, i) => (
            <div class="hero-stat" style={`--si: ${i}`}>
              <span class="hero-stat-value">{s.value}</span>
              <span class="hero-stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <div class="hero-bottom-fade" aria-hidden="true" />
</section>

<style>
/* ── Shell ────────────────────────────────────────────────── */
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.hero-full    { min-height: 92vh; }
.hero-compact { min-height: 460px; }

/* ── Background layers ────────────────────────────────────── */
.hero-bg {
  position: absolute;
  inset: 0;
  background-color: var(--color-steel-950);
  background-size: cover;
  background-position: center 35%;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, rgba(10,14,19,0.94) 0%, rgba(10,14,19,0.65) 55%, rgba(10,14,19,0.30) 100%),
    linear-gradient(to top, rgba(10,14,19,0.75) 0%, transparent 45%);
}
.hero-grid-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.035;
  background-image:
    repeating-linear-gradient(90deg, #ffffff 0, #ffffff 1px, transparent 1px, transparent 72px),
    repeating-linear-gradient(0deg,  #ffffff 0, #ffffff 1px, transparent 1px, transparent 72px);
}
.hero-red-stripe {
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  width: 3px;
  background-color: var(--color-primary);
}

/* ── Content layout ───────────────────────────────────────── */
.hero-body {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  align-items: center;
  padding-block: 88px 52px;
}
.hero-compact .hero-body { padding-block: 64px; }

.hero-content {
  max-width: 760px;
}

/* ── Eyebrow ──────────────────────────────────────────────── */
.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #ffffff;
  background-color: var(--color-primary);
}
.hero-location {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.45);
}

/* ── Headline ─────────────────────────────────────────────── */
.hero-headline {
  margin-bottom: 28px;
  line-height: 1.05;
}
.hero-headline-compact { font-size: clamp(28px, 4vw, 48px); }

/* ── Subheadline ──────────────────────────────────────────── */
.hero-sub {
  font-size: clamp(15px, 1.8vw, 18px);
  line-height: 1.65;
  color: var(--color-steel-300);
  max-width: 560px;
  margin-bottom: 44px;
}

/* ── CTA buttons ──────────────────────────────────────────── */
.hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.hero-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 28px;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #ffffff;
  background-color: var(--color-primary);
  text-decoration: none;
  transition: background-color 200ms, gap 200ms;
}
.hero-btn-primary:hover { background-color: #9a0010; gap: 14px; }

.hero-btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 16px 24px;
  font-size: 14px;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  border: 1px solid rgba(255,255,255,0.2);
  text-decoration: none;
  transition: color 200ms, border-color 200ms;
}
.hero-btn-secondary:hover { color: #ffffff; border-color: rgba(255,255,255,0.5); }

/* ── Stats bar ────────────────────────────────────────────── */
.hero-stats-bar {
  position: relative;
  z-index: 3;
  border-top: 1px solid rgba(255,255,255,0.10);
  background-color: rgba(10,14,19,0.70);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  padding-block: 28px;
}
.hero-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
}
@media (min-width: 640px) { .hero-stats { grid-template-columns: repeat(4, 1fr); } }

.hero-stat {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 8px 0;
  border-right: 1px solid rgba(255,255,255,0.07);
}
.hero-stat:last-child { border-right: none; }
@media (max-width: 639px) {
  .hero-stat:nth-child(2) { border-right: none; }
  .hero-stat:nth-child(3) { border-right: 1px solid rgba(255,255,255,0.07); }
  .hero-stat { padding-right: 20px; }
  .hero-stat:nth-child(1),
  .hero-stat:nth-child(3) { padding-left: 0; }
  .hero-stat:nth-child(2),
  .hero-stat:nth-child(4) { padding-left: 24px; }
}
@media (min-width: 640px) {
  .hero-stat { padding-inline: 24px; }
  .hero-stat:first-child { padding-left: 0; }
}

.hero-stat-value {
  font-family: var(--font-display);
  font-size: clamp(28px, 3vw, 40px);
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--color-primary);
  line-height: 1;
}
.hero-stat-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
}

/* ── Bottom fade ──────────────────────────────────────────── */
.hero-bottom-fade {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 70% 50%, rgba(186,0,19,0.04) 0%, transparent 65%);
  pointer-events: none;
  z-index: 1;
}

/* ── Entrance animations ──────────────────────────────────── */
.hero-anim {
  animation: hero-rise 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
}
.hero-anim-1 { animation-delay: 0ms; }
.hero-anim-2 { animation-delay: 80ms; }
.hero-anim-3 { animation-delay: 180ms; }
.hero-anim-4 { animation-delay: 280ms; }
.hero-anim-5 { animation-delay: 400ms; animation-name: hero-fade; }

@keyframes hero-rise {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: none; }
}
@keyframes hero-fade {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@media (prefers-reduced-motion: reduce) {
  .hero-anim { animation: none; }
}
</style>
