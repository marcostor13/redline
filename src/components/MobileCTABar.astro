<div class="mobile-cta-bar">
  <a href="tel:+16303637251" class="mobile-cta-phone">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.01 2.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
    </svg>
    Call Now
  </a>
  <div class="mobile-cta-divider" aria-hidden="true"></div>
  <a href="/quote/" class="mobile-cta-quote">
    Free Quote
  </a>
</div>

<style>
.mobile-cta-phone {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--color-steel-300);
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  transition: color 150ms;
}
.mobile-cta-phone:hover { color: #fff; }
.mobile-cta-divider {
  width: 1px;
  height: 24px;
  background-color: var(--color-steel-700);
}
.mobile-cta-quote {
  color: #ffffff;
  background-color: var(--color-primary);
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  padding: 8px 20px;
  border-radius: var(--radius);
  transition: background-color 150ms;
}
.mobile-cta-quote:hover { background-color: var(--color-primary-hover); }
</style>
