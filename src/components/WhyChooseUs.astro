---
const stats = [
  { num: '34+', label: 'Years of Experience', desc: 'Field installer since 1990, John Korabik has done it all.' },
  { num: '500+', label: 'Projects Completed', desc: 'Single-bay repairs to 200,000 sq ft full builds.' },
  { num: '50', label: 'States Served', desc: 'Travel projects nationwide, logistics coordinated for you.' },
  { num: '100%', label: 'In-House Crews', desc: 'No subcontractors. Every installer is Redline-trained.' },
];

const features = [
  'OSHA-compliant on every job, every time',
  'ANSI MH16.1 certified rack standards',
  'Free on-site assessment before any commitment',
  '4-hour response time on all B2B inquiries',
  'All major rack brands supported',
  'Emergency and fast-track projects accepted',
];
---

<section class="why-section">
  <div class="container">

    <div class="why-header" data-animate>
      <p class="text-eyebrow">Why Redline</p>
      <h2 class="text-headline-lg why-title section-heading">
        Built on 34 Years of<br>Industrial Experience
      </h2>
    </div>

    <div class="stats-grid" data-animate-stagger>
      {stats.map(({ num, label, desc }) => (
        <div class="stat-block">
          <div class="stat-number">{num}</div>
          <p class="stat-label">{label}</p>
          <p class="stat-desc">{desc}</p>
        </div>
      ))}
    </div>

    <div class="features-grid" data-animate-stagger>
      {features.map(f => (
        <div class="feature-item">
          <span class="feature-check" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          <span class="feature-text">{f}</span>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
.why-section {
  padding-block: 100px;
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}
.why-header {
  margin-bottom: 60px;
}
.why-title {
  max-width: 500px;
  margin-top: 16px;
  color: var(--color-on-surface);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  border-top: 1px solid var(--color-border);
  border-left: 1px solid var(--color-border);
  margin-bottom: 64px;
}
@media (min-width: 768px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }

.stat-block {
  padding: 36px 28px;
  border-right: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.stat-label {
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 700;
  color: var(--color-on-surface);
  margin: 0;
}
.stat-desc {
  font-size: 13px;
  color: var(--color-on-surface-muted);
  line-height: 1.5;
  margin: 0;
}

.features-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}
@media (min-width: 640px)  { .features-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .features-grid { grid-template-columns: repeat(3, 1fr); } }

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px 0;
  border-bottom: 1px solid var(--color-border);
}
.feature-check {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: var(--color-primary-subtle);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1px;
}
.feature-text {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-on-surface);
  line-height: 1.5;
}
</style>
