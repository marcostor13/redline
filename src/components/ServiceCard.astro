---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  featured?: boolean;
  num?: string;
}
const { title, description, href, icon, featured = false, num } = Astro.props;
---

<article class={`svc-card ${featured ? 'svc-card-featured' : ''}`}>
  {num && <span class="svc-num" aria-hidden="true">{num}</span>}
  {!num && icon && (
    <span class="svc-icon" aria-hidden="true">{icon}</span>
  )}
  <h3 class="svc-title">
    <a href={href} class="svc-title-link">{title}</a>
  </h3>
  <p class="svc-desc">{description}</p>
  <a href={href} class="btn-text svc-cta">
    Learn more
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6" />
    </svg>
  </a>
</article>

<style>
.svc-card {
  padding: 32px 28px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: border-color 200ms, background-color 200ms;
}
.svc-card:hover {
  border-color: var(--color-primary);
  background-color: var(--color-surface-alt);
}
.svc-card-featured {
  border-top: 3px solid var(--color-primary);
}

.svc-num {
  font-family: var(--font-display);
  font-size: 52px;
  font-weight: 200;
  letter-spacing: -0.04em;
  color: var(--color-steel-200);
  line-height: 1;
  user-select: none;
  display: block;
  margin-bottom: 4px;
}

.svc-icon {
  font-size: 28px;
  display: block;
  margin-bottom: 4px;
}

.svc-title {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  letter-spacing: -0.01em;
  line-height: 1.2;
  color: var(--color-on-surface);
  margin: 0;
}
.svc-title-link {
  color: inherit;
  text-decoration: none;
  transition: color 150ms;
}
.svc-title-link:hover { color: var(--color-primary); }

.svc-desc {
  font-size: 15px;
  line-height: 1.6;
  color: var(--color-on-surface-muted);
  flex: 1;
  margin: 0;
}

.svc-cta {
  margin-top: 8px;
  font-size: 13px;
}
</style>
