---
import ClientRouter from 'astro/components/ClientRouter.astro';
import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileCTABar from '../components/MobileCTABar.astro';
import FloatingQuoteCTA from '../components/FloatingQuoteCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  schema,
  bodyClass = '',
} = Astro.props;

// Base LocalBusiness schema always present on all pages
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://redlineinstallers.com/#business',
  name: 'Redline Installers LLC',
  description: 'Warehouse & material handling installation specialists serving Illinois, Midwest, and nationwide.',
  url: 'https://redlineinstallers.com',
  telephone: '+1-630-363-7251',
  email: 'jk@redlineinstallers.com',
  foundingDate: '1990',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '980 N Michigan Ave Ste 1090 PMB 357073',
    addressLocality: 'Chicago',
    addressRegion: 'IL',
    postalCode: '60611-4521',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 41.9002,
    longitude: -87.6237,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '07:00',
      closes: '18:00',
    },
  ],
  areaServed: {
    '@type': 'Country',
    name: 'United States',
  },
  priceRange: '$$',
  knowsAbout: ['Pallet Rack Installation', 'Warehouse Relocation', 'Material Handling Systems'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Warehouse & Material Handling Installation Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Pallet Rack Installation', url: 'https://redlineinstallers.com/services/pallet-rack-installation/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Warehouse Relocation', url: 'https://redlineinstallers.com/services/warehouse-relocation/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Rack Repair & Modifications', url: 'https://redlineinstallers.com/services/rack-repair-modifications/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Mezzanine Installation', url: 'https://redlineinstallers.com/services/mezzanine-installation/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Conveyor Systems', url: 'https://redlineinstallers.com/services/conveyor-systems/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Tear-Down & Reinstallation', url: 'https://redlineinstallers.com/services/tear-down-reinstallation/' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Material Handling Systems', url: 'https://redlineinstallers.com/services/material-handling-systems/' } },
    ],
  },
  sameAs: [],
};

const schemas: Record<string, unknown>[] = [localBusinessSchema];
if (schema) {
  if (Array.isArray(schema)) schemas.push(...schema);
  else schemas.push(schema);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0A0E13" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/jpeg" href="/logo.jpg" />
    <link rel="apple-touch-icon" href="/logo.jpg" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <JsonLd schema={schemas} />
    <ClientRouter />
  </head>
  <body class={`min-h-screen flex flex-col pb-[60px] lg:pb-0 ${bodyClass}`}>

    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
    <MobileCTABar />
    <FloatingQuoteCTA />

  </body>
</html>

<script>
  function initScrollAnimations() {
    // Individual element reveals
    const singles = document.querySelectorAll('[data-animate]:not(.is-visible)');
    if (singles.length) {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              obs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -48px 0px' }
      );
      singles.forEach((el) => obs.observe(el));
    }

    // Stagger grid reveals
    const grids = document.querySelectorAll('[data-animate-stagger]');
    if (grids.length) {
      const gridObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              Array.from(e.target.children).forEach((child, i) => {
                (child as HTMLElement).style.transitionDelay = `${i * 75}ms`;
                child.classList.add('is-visible');
              });
              gridObs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
      );
      grids.forEach((el) => gridObs.observe(el));
    }
  }

  // Runs on first load and after every View Transition navigation
  document.addEventListener('astro:page-load', initScrollAnimations);
</script>
