---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

export async function getStaticPaths() {
  const industries = await getCollection('industries');
  return industries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allServices = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://redlineinstallers.com/' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://redlineinstallers.com/industries/' },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: `https://redlineinstallers.com/industries/${entry.id}/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Warehouse Installation for ${entry.data.title}`,
  description: entry.data.description,
  provider: {
    '@type': 'LocalBusiness',
    '@id': 'https://redlineinstallers.com/#business',
    name: 'Redline Installers LLC',
    telephone: '+1-630-363-7251',
    url: 'https://redlineinstallers.com',
  },
  serviceType: 'Warehouse Installation',
  areaServed: [
    { '@type': 'State', name: 'Illinois' },
    { '@type': 'Country', name: 'United States' },
  ],
  url: `https://redlineinstallers.com/industries/${entry.id}/`,
};
---

<BaseLayout
  title={entry.data.metaTitle ?? `${entry.data.title} Warehouse Installation | Redline Installers LLC`}
  description={entry.data.metaDescription ?? entry.data.description}
  canonical={`https://redlineinstallers.com/industries/${entry.id}/`}
  schema={[breadcrumbSchema, serviceSchema]}
>

  <Hero
    headline={`${entry.data.title} Warehouse & Rack Installation`}
    subheadline={entry.data.description}
    compact={true}
  />

  <!-- Breadcrumb -->
  <nav class="py-3 border-b" style="background-color: var(--color-surface-alt); border-color: var(--color-border);" aria-label="Breadcrumb">
    <div class="container">
      <ol class="flex items-center gap-2 text-sm" style="color: var(--color-on-surface-muted);">
        <li><a href="/" style="color: var(--color-on-surface-muted);" class="hover:underline">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/industries/" style="color: var(--color-on-surface-muted);" class="hover:underline">Industries</a></li>
        <li aria-hidden="true">/</li>
        <li style="color: var(--color-on-surface);" aria-current="page">{entry.data.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Industry Detail -->
  <section class="py-16" style="background-color: var(--color-surface);">
    <div class="container">
      <div class="max-w-3xl">
        <div class="prose-content">
          <Content />
        </div>
      </div>
    </div>
  </section>

  <!-- Services for this Industry -->
  <section class="py-16" style="background-color: var(--color-steel-50);">
    <div class="container">
      <div class="max-w-2xl mb-10">
        <span class="text-label-sm block mb-3" style="color: var(--color-primary);">What We Install</span>
        <h2 class="text-headline-lg font-display" style="color: var(--color-on-surface);">
          Services We Provide for {entry.data.title}
        </h2>
        <p class="text-body-lg mt-4" style="color: var(--color-on-surface-muted);">
          Every service below is available for {entry.data.title.toLowerCase()} operations — from a single rack
          repair to a complete facility build-out.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {allServices.map((svc, i) => (
          <ServiceCard
            title={svc.data.title}
            description={svc.data.shortDesc}
            href={`/services/${svc.id}/`}
            icon={svc.data.icon}
            featured={i === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Statement -->
  <section class="py-16" style="background-color: var(--color-surface);">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <div class="text-4xl mb-4" aria-hidden="true">{entry.data.icon}</div>
        <h2 class="text-headline-lg font-display mb-4" style="color: var(--color-on-surface);">
          34+ Years Serving {entry.data.title} Operations
        </h2>
        <p class="text-body-lg mb-8" style="color: var(--color-on-surface-muted);">
          Redline Installers LLC is founded by John Korabik, a field installer since 1990. Every project is
          managed by an experienced crew lead — no subcontractors, no learning curve on your floor.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/quote/" class="btn-primary">Request a Free Quote</a>
          <a href="tel:+16303637251" class="btn-outline">Call 630-363-7251</a>
        </div>
      </div>
    </div>
  </section>

  <CTASection />

</BaseLayout>

<style>
  .font-display { font-family: var(--font-display); }

  .prose-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-on-surface);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-on-surface);
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .prose-content :global(p) {
    color: var(--color-on-surface-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    color: var(--color-on-surface-muted);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }

  .prose-content :global(strong) {
    color: var(--color-on-surface);
    font-weight: 600;
  }
</style>
