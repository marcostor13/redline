---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { QuoteWizard } from '../../components/QuoteWizard';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Warehouse Installation Quote Request',
    provider: {
      '@type': 'LocalBusiness',
      '@id': 'https://redlineinstallers.com/#business',
      name: 'Redline Installers LLC',
    },
    areaServed: { '@type': 'Country', name: 'United States' },
    description: 'Free quote for pallet rack installation, warehouse relocation, mezzanine installation, and material handling systems.',
    url: 'https://redlineinstallers.com/quote/',
  },
];
---

<BaseLayout
  title="Request a Free Quote | Redline Installers LLC"
  description="Get a free warehouse installation quote in 4 quick steps. Expert pallet rack, mezzanine, and material handling installation. Response within 4 business hours."
  canonical="https://redlineinstallers.com/quote/"
  schema={schema}
>

  <!-- Page hero -->
  <section class="quote-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="quote-breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Request a Quote</span>
      </nav>
      <div class="quote-hero-inner">
        <div>
          <p class="text-eyebrow" style="color: var(--color-primary); margin-bottom: 10px;">Free Estimate</p>
          <h1 class="text-headline-lg" style="color: #ffffff; max-width: 560px;">
            Get Your Free Project Quote
          </h1>
          <p style="color: var(--color-steel-300); font-size: 16px; line-height: 1.65; max-width: 480px; margin-top: 14px;">
            Answer 4 quick questions. John Korabik personally reviews every request and responds within 4 business hours.
          </p>
        </div>
        <div class="quote-hero-trust">
          <div class="qh-trust-item">
            <span class="qh-trust-num">34+</span>
            <span class="qh-trust-label">Years experience</span>
          </div>
          <div class="qh-trust-item">
            <span class="qh-trust-num">&lt; 4h</span>
            <span class="qh-trust-label">Response time</span>
          </div>
          <div class="qh-trust-item">
            <span class="qh-trust-num">$0</span>
            <span class="qh-trust-label">Assessment fee</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="quote-body">
    <div class="container">
      <div class="quote-layout">

        <!-- Wizard -->
        <div class="quote-wizard-col">
          <QuoteWizard client:load />
        </div>

        <!-- Sidebar -->
        <aside class="quote-sidebar">

          <div class="qs-card qs-card-featured">
            <p class="qs-card-eyebrow">What happens next</p>
            <ol class="qs-steps">
              <li class="qs-step">
                <span class="qs-step-n">1</span>
                <div>
                  <p class="qs-step-title">We review your request</p>
                  <p class="qs-step-body">John personally reads every submission — no automated routing. Response within 4 business hours.</p>
                </div>
              </li>
              <li class="qs-step">
                <span class="qs-step-n">2</span>
                <div>
                  <p class="qs-step-title">John contacts you directly</p>
                  <p class="qs-step-body">He'll call or email to clarify scope and understand your timeline.</p>
                </div>
              </li>
              <li class="qs-step">
                <span class="qs-step-n">3</span>
                <div>
                  <p class="qs-step-title">Free site assessment</p>
                  <p class="qs-step-body">For qualifying projects, we schedule a no-cost on-site walkthrough before finalizing the quote.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="qs-card qs-card-contact">
            <p class="qs-contact-label">Prefer to reach us directly?</p>
            <a href="tel:+16303637251" class="qs-contact-row">
              <span class="qs-contact-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </span>
              <div>
                <span class="qs-contact-hint">Call John directly</span>
                <span class="qs-contact-value">630-363-7251</span>
              </div>
            </a>
            <a href="mailto:jk@redlineinstallers.com" class="qs-contact-row">
              <span class="qs-contact-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <div>
                <span class="qs-contact-hint">Email</span>
                <span class="qs-contact-value" style="font-size: 14px;">jk@redlineinstallers.com</span>
              </div>
            </a>
          </div>

          <div class="qs-trust-block">
            <p class="qs-trust-num">34+</p>
            <p class="qs-trust-headline">Years of Installation Experience</p>
            <p class="qs-trust-body">John Korabik has installed, relocated, and repaired pallet rack systems across Illinois, the Midwest, and nationwide since 1990.</p>
            <ul class="qs-bullets">
              {[
                'OSHA-compliant installations',
                'All major rack brands supported',
                'IL, Midwest & nationwide service',
                'Free site assessments available',
                'Zero subcontractors — ever',
              ].map(b => (
                <li class="qs-bullet">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#ba0013" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {b}
                </li>
              ))}
            </ul>
          </div>

        </aside>

      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
/* ============================================================
   Quote Wizard — all styles scoped under .qw- prefix
   ============================================================ */

/* ── Root ─────────────────────────────────────────────────── */
.qw-root {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-top: 3px solid var(--color-primary);
}

/* ── Progress ─────────────────────────────────────────────── */
.qw-progress-wrap {
  padding: 28px 32px 0;
}
.qw-progress-track {
  height: 2px;
  background: var(--color-steel-100);
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
}
.qw-progress-fill {
  position: absolute;
  inset-block: 0;
  left: 0;
  background: var(--color-primary);
  transition: width 400ms cubic-bezier(0.22, 1, 0.36, 1);
}
.qw-progress-steps {
  display: flex;
  justify-content: space-between;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--color-border);
}
.qw-prog-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  flex: 1;
}
.qw-prog-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 700;
  color: var(--color-on-surface-muted);
  background: var(--color-surface);
  transition: border-color 300ms, background 300ms, color 300ms;
}
.qw-prog-step.active .qw-prog-dot {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: #fff;
}
.qw-prog-step.done .qw-prog-dot {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: #fff;
}
.qw-prog-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-steel-400);
  white-space: nowrap;
}
.qw-prog-step.active .qw-prog-label { color: var(--color-primary); }
.qw-prog-step.done  .qw-prog-label  { color: var(--color-on-surface-muted); }

/* ── Step wrapper + animations ────────────────────────────── */
.qw-step-wrap {
  padding: 32px 32px 24px;
  min-height: 320px;
}
.qw-step-wrap.qw-fwd {
  animation: qw-slide-fwd 320ms cubic-bezier(0.22, 1, 0.36, 1) both;
}
.qw-step-wrap.qw-bck {
  animation: qw-slide-bck 320ms cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes qw-slide-fwd {
  from { opacity: 0; transform: translateX(24px); }
  to   { opacity: 1; transform: none; }
}
@keyframes qw-slide-bck {
  from { opacity: 0; transform: translateX(-24px); }
  to   { opacity: 1; transform: none; }
}

/* ── Step typography ──────────────────────────────────────── */
.qw-step-header { margin-bottom: 28px; }
.qw-step-title {
  font-family: var(--font-display);
  font-size: clamp(20px, 2.5vw, 26px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-on-surface);
  margin-bottom: 6px;
}
.qw-step-sub {
  font-size: 14px;
  color: var(--color-on-surface-muted);
  line-height: 1.5;
}

/* ── Service cards ────────────────────────────────────────── */
.qw-service-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 8px;
}
@media (min-width: 640px) { .qw-service-grid { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 960px) { .qw-service-grid { grid-template-columns: repeat(4, 1fr); } }

.qw-service-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6px;
  padding: 14px 14px 14px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  cursor: pointer;
  text-align: left;
  transition: border-color 200ms, background 200ms;
}
.qw-service-card:hover { border-color: var(--color-primary); }
.qw-service-card.selected {
  border-color: var(--color-primary);
  background: #fff5f5;
}
.qw-svc-check {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.6);
  transition: opacity 200ms, transform 200ms;
}
.qw-service-card.selected .qw-svc-check {
  opacity: 1;
  transform: scale(1);
}
.qw-svc-name {
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 700;
  color: var(--color-on-surface);
  line-height: 1.3;
  padding-right: 20px;
}
.qw-svc-desc {
  font-size: 11px;
  color: var(--color-on-surface-muted);
  line-height: 1.4;
  display: none;
}
@media (min-width: 640px) { .qw-svc-desc { display: block; } }

/* ── Fields ───────────────────────────────────────────────── */
.qw-row-2 {
  display: grid;
  gap: 16px;
  margin-bottom: 20px;
}
@media (min-width: 540px) { .qw-row-2 { grid-template-columns: 1fr 1fr; } }

.qw-field { margin-bottom: 20px; }
.qw-field:last-child { margin-bottom: 0; }

.qw-req    { color: var(--color-primary); font-size: 13px; margin-left: 2px; }
.qw-optional { color: var(--color-steel-400); font-size: 10px; margin-left: 4px; }

.qw-input-error { border-color: var(--color-error) !important; border-width: 2px !important; }

.qw-field-error {
  font-size: 12px;
  color: var(--color-error);
  margin-top: 4px;
  display: flex;
  align-items: center;
  gap: 4px;
}

.qw-textarea { resize: vertical; min-height: 88px; }

/* ── Chips ────────────────────────────────────────────────── */
.qw-chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
}
.qw-chip {
  padding: 8px 14px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  font-size: 13px;
  font-weight: 600;
  color: var(--color-on-surface);
  cursor: pointer;
  transition: border-color 180ms, color 180ms, background 180ms;
  white-space: nowrap;
}
.qw-chip:hover  { border-color: var(--color-primary); color: var(--color-primary); }
.qw-chip.selected {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: #fff;
}
.qw-chip-stacked {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 10px 14px;
  gap: 2px;
}
.qw-chip-main { font-size: 13px; font-weight: 700; }
.qw-chip-sub  { font-size: 10px; font-weight: 500; opacity: 0.8; }

/* ── Budget cards ─────────────────────────────────────────── */
.qw-budget-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 8px;
}
@media (min-width: 640px) { .qw-budget-grid { grid-template-columns: repeat(3, 1fr); } }

.qw-budget-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 700;
  color: var(--color-on-surface);
  cursor: pointer;
  text-align: left;
  transition: border-color 180ms, background 180ms, color 180ms;
}
.qw-budget-card:hover   { border-color: var(--color-primary); color: var(--color-primary); }
.qw-budget-card.selected {
  border-color: var(--color-primary);
  background: #fff5f5;
  color: var(--color-primary);
}
.qw-budget-check {
  flex-shrink: 0;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.6);
  transition: opacity 200ms, transform 200ms;
}
.qw-budget-card.selected .qw-budget-check { opacity: 1; transform: scale(1); }

/* ── Nav ──────────────────────────────────────────────────── */
.qw-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 32px 28px;
  border-top: 1px solid var(--color-border);
  background: var(--color-surface-alt);
}
.qw-nav-left { display: flex; align-items: center; }
.qw-nav-right {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-left: auto;
}
.qw-step-counter {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--color-steel-400);
}
.qw-btn-back {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 16px;
  font-size: 14px;
  font-weight: 600;
  color: var(--color-on-surface-muted);
  background: none;
  border: 1px solid var(--color-border);
  cursor: pointer;
  text-decoration: none;
  transition: color 150ms, border-color 150ms;
}
.qw-btn-back:hover { color: var(--color-on-surface); border-color: var(--color-on-surface); }

.qw-btn-next {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.03em;
  color: #fff;
  background: var(--color-primary);
  border: none;
  cursor: pointer;
  transition: background 180ms, gap 180ms;
  text-decoration: none;
}
.qw-btn-next:hover:not(:disabled)  { background: #9a0010; gap: 12px; }
.qw-btn-next:disabled { opacity: 0.7; cursor: not-allowed; }

.qw-submit-error {
  font-size: 13px;
  color: var(--color-error);
  padding: 12px 32px;
  background: var(--color-error-subtle);
  border-top: 1px solid var(--color-error);
  margin: 0;
}

/* ── Success ──────────────────────────────────────────────── */
.qw-success {
  padding: 48px 32px;
  text-align: center;
}
.qw-success-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  animation: qw-success-pop 500ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
}
@keyframes qw-success-pop {
  from { opacity: 0; transform: scale(0.5); }
  to   { opacity: 1; transform: scale(1); }
}
.qw-success-title {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 700;
  color: var(--color-on-surface);
  margin-bottom: 12px;
}
.qw-success-body {
  font-size: 16px;
  color: var(--color-on-surface-muted);
  line-height: 1.6;
  max-width: 460px;
  margin: 0 auto 32px;
}
.qw-success-steps {
  display: flex;
  flex-direction: column;
  gap: 16px;
  text-align: left;
  max-width: 420px;
  margin: 0 auto 32px;
  border-top: 1px solid var(--color-border);
  padding-top: 24px;
}
.qw-success-step {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}
.qw-success-step-n {
  flex-shrink: 0;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.qw-success-step-title { font-size: 14px; font-weight: 700; color: var(--color-on-surface); margin-bottom: 2px; }
.qw-success-step-body  { font-size: 13px; color: var(--color-on-surface-muted); }
.qw-success-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .qw-step-wrap         { animation: none !important; }
  .qw-success-icon      { animation: none !important; }
  .qw-progress-fill     { transition: none !important; }
  .qw-prog-dot          { transition: none !important; }
}
</style>

<style>
/* ── Page hero ────────────────────────────────────────────── */
.quote-hero {
  background-color: var(--color-steel-950);
  padding-block: 52px 48px;
  border-bottom: 1px solid var(--color-steel-800);
}
.quote-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--color-steel-400);
  margin-bottom: 24px;
}
.quote-breadcrumb a { color: var(--color-steel-400); text-decoration: none; transition: color 150ms; }
.quote-breadcrumb a:hover { color: #fff; }

.quote-hero-inner {
  display: flex;
  flex-direction: column;
  gap: 28px;
  align-items: flex-start;
}
@media (min-width: 768px) {
  .quote-hero-inner {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.quote-hero-trust {
  display: flex;
  gap: 0;
  border: 1px solid var(--color-steel-700);
  flex-shrink: 0;
}
.qh-trust-item {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 16px 24px;
  border-right: 1px solid var(--color-steel-700);
}
.qh-trust-item:last-child { border-right: none; }
.qh-trust-num {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--color-primary);
  line-height: 1;
}
.qh-trust-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
}

/* ── Body ─────────────────────────────────────────────────── */
.quote-body {
  background: var(--color-surface-alt);
  padding-block: 40px 80px;
}
.quote-layout {
  display: grid;
  gap: 32px;
  align-items: start;
}
@media (min-width: 1024px) {
  .quote-layout { grid-template-columns: 1fr 360px; }
}

/* ── Sidebar ──────────────────────────────────────────────── */
.quote-sidebar { display: flex; flex-direction: column; gap: 20px; }
@media (min-width: 1024px) { .quote-sidebar { position: sticky; top: 88px; } }

.qs-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  padding: 28px;
}
.qs-card-featured { border-top: 3px solid var(--color-primary); }

.qs-card-eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: 20px;
}

.qs-steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 18px; }
.qs-step  { display: flex; gap: 14px; align-items: flex-start; }
.qs-step-n {
  flex-shrink: 0;
  width: 26px; height: 26px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-top: 1px;
}
.qs-step-title {
  font-size: 14px; font-weight: 700;
  color: var(--color-on-surface);
  margin-bottom: 3px;
}
.qs-step-body {
  font-size: 13px;
  color: var(--color-on-surface-muted);
  line-height: 1.5;
}

.qs-card-contact { border-left: 3px solid var(--color-primary); }
.qs-contact-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
