---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://redlineinstallers.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://redlineinstallers.com/services/' },
  ],
};
---

<BaseLayout
  title="Warehouse Installation Services | Redline Installers LLC"
  description="Pallet rack installation, warehouse relocation, mezzanine installation, conveyor systems, and material handling — professional warehouse installation services in Illinois, Midwest, and nationwide."
  canonical="https://redlineinstallers.com/services/"
  schema={breadcrumbSchema}
>

  <!-- Page Hero -->
  <section class="py-20" style="background: linear-gradient(135deg, #0A0E13 0%, #1A2129 60%, #2A323D 100%);">
    <div class="container">
      <div class="max-w-3xl">
        <span class="text-label-sm block mb-3" style="color: var(--color-primary);">
          Warehouse & Material Handling Specialists
        </span>
        <h1 class="text-display text-white mb-6">
          Warehouse & Material Handling Installation Services
        </h1>
        <p class="text-body-lg mb-8" style="color: var(--color-steel-300);">
          Specialized installation crews for every warehouse and material handling system. No subcontractors —
          our teams are trained, insured, and OSHA-compliant. Serving Illinois, the Midwest, and all 50 states
          since 1990.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/quote/" class="btn-primary">Request a Free Quote</a>
          <a href="tel:+16303637251" class="btn-outline-light">Call 630-363-7251</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20" style="background-color: var(--color-surface);">
    <div class="container">
      <div class="max-w-2xl mb-12">
        <span class="text-label-sm block mb-3" style="color: var(--color-primary);">What We Do</span>
        <h2 class="text-headline-lg section-heading" style="color: var(--color-on-surface); font-family: var(--font-display);">
          Every Installation Service Your Warehouse Needs
        </h2>
        <p class="text-body-lg mt-6" style="color: var(--color-on-surface-muted);">
          From a single damaged upright to a complete 200,000 sq ft material handling system build-out —
          Redline Installers has a specialized crew for every scope. John Korabik and his team bring 34+ years
          of field experience to every project.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((svc, i) => (
          <ServiceCard
            title={svc.data.title}
            description={svc.data.shortDesc}
            href={`/services/${svc.id}/`}
            icon={svc.data.icon}
            featured={i === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Why Redline strip -->
  <section class="py-16" style="background-color: var(--color-steel-50);">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-headline-lg font-display mb-2" style="color: var(--color-primary);">34+</div>
          <div class="text-body-md font-semibold mb-1" style="color: var(--color-on-surface);">Years Installing</div>
          <div class="text-body-md" style="color: var(--color-on-surface-muted);">Founded by John Korabik, a field installer since 1990</div>
        </div>
        <div>
          <div class="text-headline-lg font-display mb-2" style="color: var(--color-primary);">50</div>
          <div class="text-body-md font-semibold mb-1" style="color: var(--color-on-surface);">States Served</div>
          <div class="text-body-md" style="color: var(--color-on-surface-muted);">Nationwide travel projects with logistics coordination included</div>
        </div>
        <div>
          <div class="text-headline-lg font-display mb-2" style="color: var(--color-primary);">0</div>
          <div class="text-body-md font-semibold mb-1" style="color: var(--color-on-surface);">Subcontractors</div>
          <div class="text-body-md" style="color: var(--color-on-surface-muted);">Every crew member is a trained Redline employee</div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />

</BaseLayout>

<style>
  .font-display { font-family: var(--font-display); }
</style>
