---
import BaseLayout from '../../layouts/BaseLayout.astro';

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Privacy Policy',
  url: 'https://redlineinstallers.com/privacy/',
  isPartOf: { '@id': 'https://redlineinstallers.com/#website' },
  about: { '@id': 'https://redlineinstallers.com/#business' },
  description: 'Privacy policy for Redline Installers LLC. Covers data collection, use, sharing, cookies, and your rights under applicable law.',
};
---

<BaseLayout
  title="Privacy Policy | Redline Installers LLC"
  description="Privacy policy for Redline Installers LLC. Covers data collection, use, sharing, cookies, and your rights under applicable law."
  canonical="https://redlineinstallers.com/privacy/"
  noindex={true}
  schema={webPageSchema}
>

  <section class="py-16" style="background-color: var(--color-surface);">
    <div class="container">
      <div class="max-w-3xl mx-auto">

        <div class="mb-10">
          <h1 class="text-headline-lg mb-3" style="color: var(--color-on-surface); font-family: var(--font-display);">
            Privacy Policy
          </h1>
          <p class="text-body-md" style="color: var(--color-on-surface-muted);">
            Last updated: May 2025
          </p>
        </div>

        <div class="text-body-md prose-section" style="color: var(--color-on-surface-muted);">

          <p style="margin-bottom: 24px; color: var(--color-on-surface);">
            Redline Installers LLC ("Redline Installers," "we," "us," or "our") operates the website at redlineinstallers.com (the "Site"). This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our Site or contact us about our services.
          </p>

          <!-- Section 1 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            1. Information We Collect
          </h2>

          <p style="margin-bottom: 16px;">
            We collect information that you voluntarily provide to us when you fill out a contact or quote request form on our Site. This includes:
          </p>
          <ul style="margin-bottom: 16px; padding-left: 24px; list-style: disc;">
            <li style="margin-bottom: 8px;">Name and company name</li>
            <li style="margin-bottom: 8px;">Email address and phone number</li>
            <li style="margin-bottom: 8px;">Project location and project type</li>
            <li style="margin-bottom: 8px;">Project details you provide in free-text fields</li>
          </ul>

          <p style="margin-bottom: 16px;">
            We also collect limited technical information automatically when you visit the Site, including:
          </p>
          <ul style="margin-bottom: 16px; padding-left: 24px; list-style: disc;">
            <li style="margin-bottom: 8px;">IP address and approximate geographic location</li>
            <li style="margin-bottom: 8px;">Browser type and operating system</li>
            <li style="margin-bottom: 8px;">Pages visited and time spent on pages</li>
            <li style="margin-bottom: 8px;">Referring URL</li>
          </ul>

          <p style="margin-bottom: 16px;">
            We do not collect payment card numbers, Social Security numbers, or other sensitive personal data through this Site.
          </p>

          <!-- Section 2 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            2. How We Use Your Information
          </h2>

          <p style="margin-bottom: 16px;">
            We use the information we collect to:
          </p>
          <ul style="margin-bottom: 16px; padding-left: 24px; list-style: disc;">
            <li style="margin-bottom: 8px;">Respond to your quote requests and project inquiries</li>
            <li style="margin-bottom: 8px;">Schedule site assessments and coordinate project details</li>
            <li style="margin-bottom: 8px;">Communicate about ongoing projects and service updates</li>
            <li style="margin-bottom: 8px;">Improve the content and performance of our Site</li>
            <li style="margin-bottom: 8px;">Comply with legal obligations</li>
          </ul>

          <p style="margin-bottom: 16px;">
            We do not use your information for automated decision-making or profiling. We do not sell your information to third parties or use it for advertising purposes.
          </p>

          <!-- Section 3 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            3. Data Sharing
          </h2>

          <p style="margin-bottom: 16px;">
            We do not sell, rent, or trade your personal information. We may share your information with:
          </p>
          <ul style="margin-bottom: 16px; padding-left: 24px; list-style: disc;">
            <li style="margin-bottom: 8px;"><strong style="color: var(--color-on-surface);">Service providers:</strong> Third-party vendors who assist in operating our Site and delivering our services (such as email service providers and web hosting providers). These parties are contractually prohibited from using your information for any other purpose.</li>
            <li style="margin-bottom: 8px;"><strong style="color: var(--color-on-surface);">Legal compliance:</strong> When required by law, court order, or other legal process, or when we believe disclosure is necessary to protect our rights or prevent harm.</li>
            <li style="margin-bottom: 8px;"><strong style="color: var(--color-on-surface);">Business transfers:</strong> In connection with a merger, acquisition, or sale of assets, subject to the acquirer's commitment to honor this Privacy Policy.</li>
          </ul>

          <!-- Section 4 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            4. Cookies and Tracking
          </h2>

          <p style="margin-bottom: 16px;">
            Our Site uses standard browser cookies and similar tracking technologies to maintain session information and understand how visitors use the Site. We use analytics tools that may set cookies to help us measure traffic patterns and improve user experience.
          </p>
          <p style="margin-bottom: 16px;">
            You can instruct your browser to refuse all cookies or to indicate when a cookie is being sent. If you disable cookies, some features of the Site may not function properly.
          </p>
          <p style="margin-bottom: 16px;">
            We do not use advertising cookies or cross-site tracking technologies for behavioral advertising.
          </p>

          <!-- Section 5 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            5. Data Retention
          </h2>

          <p style="margin-bottom: 16px;">
            We retain personal information you submit through our contact forms for as long as necessary to fulfill the purpose for which it was collected — typically for the duration of any active business relationship and for up to 3 years thereafter, unless a longer retention period is required by law.
          </p>
          <p style="margin-bottom: 16px;">
            You may request deletion of your information at any time by contacting us at the address below.
          </p>

          <!-- Section 6 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            6. Your Rights
          </h2>

          <p style="margin-bottom: 16px;">
            Depending on your location, you may have the following rights regarding your personal information:
          </p>
          <ul style="margin-bottom: 16px; padding-left: 24px; list-style: disc;">
            <li style="margin-bottom: 8px;"><strong style="color: var(--color-on-surface);">Access:</strong> Request a copy of the personal information we hold about you.</li>
            <li style="margin-bottom: 8px;"><strong style="color: var(--color-on-surface);">Correction:</strong> Request that we correct inaccurate or incomplete information.</li>
            <li style="margin-bottom: 8px;"><strong style="color: var(--color-on-surface);">Deletion:</strong> Request that we delete your personal information, subject to certain legal obligations.</li>
            <li style="margin-bottom: 8px;"><strong style="color: var(--color-on-surface);">Objection:</strong> Object to the processing of your personal information in certain circumstances.</li>
            <li style="margin-bottom: 8px;"><strong style="color: var(--color-on-surface);">Portability:</strong> Request a portable copy of your information in a machine-readable format.</li>
          </ul>
          <p style="margin-bottom: 16px;">
            To exercise any of these rights, contact us at <a href="mailto:jk@redlineinstallers.com" style="color: var(--color-primary); text-decoration: none;">jk@redlineinstallers.com</a>. We will respond to all legitimate requests within 30 days.
          </p>

          <!-- Section 7 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            7. Security
          </h2>

          <p style="margin-bottom: 16px;">
            We implement reasonable technical and organizational measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction. Our Site is served over HTTPS. Form submissions are transmitted using TLS encryption.
          </p>
          <p style="margin-bottom: 16px;">
            No method of transmission over the internet is 100% secure. While we strive to protect your information, we cannot guarantee absolute security.
          </p>

          <!-- Section 8 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            8. Changes to This Policy
          </h2>

          <p style="margin-bottom: 16px;">
            We may update this Privacy Policy from time to time. The updated version will be indicated by a revised "Last updated" date at the top of the page. We encourage you to review this policy periodically.
          </p>

          <!-- Section 9 -->
          <h2 style="font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--color-on-surface); margin-top: 40px; margin-bottom: 12px; padding-top: 8px; border-top: 1px solid var(--color-border);">
            9. Contact
          </h2>

          <p style="margin-bottom: 16px;">
            If you have questions about this Privacy Policy or how we handle your personal information, contact us at:
          </p>
          <address style="font-style: normal; line-height: 1.8; color: var(--color-on-surface);">
            Redline Installers LLC<br />
            Attn: Privacy<br />
            980 N Michigan Ave Ste 1090 PMB 357073<br />
            Chicago, IL 60611-4521<br />
            Email: <a href="mailto:jk@redlineinstallers.com" style="color: var(--color-primary); text-decoration: none;">jk@redlineinstallers.com</a><br />
            Phone: <a href="tel:+16303637251" style="color: var(--color-primary); text-decoration: none;">630-363-7251</a>
          </address>

        </div>

        <div class="mt-12 pt-8" style="border-top: 1px solid var(--color-border);">
          <a href="/" class="btn-outline">
            &larr; Back to Home
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
